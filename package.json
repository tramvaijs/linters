{
  "name": "linters-monorepo",
  "description": "ESlint, Stylelint and Prettier configurations",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "********** Linters": "",
    "prettier": "prettier --write '**/*.{js,ts,md,json,html}'",
    "prettier:ci": "prettier --check '**/*.{js,ts,md,json,html}'",
    "lint": "concurrently 'npm:prettier' 'npm:lint:all'",
    "lint:all": "eslint .",
    "prelint:ci": "lerna run build:prod --parallel",
    "lint:ci": "concurrently 'npm:prettier:ci' 'npm:lint:all'",
    "*** Bootstrap": "",
    "postinstall": "lerna bootstrap --hoist --ignore-prepublish && husky install",
    "********** Build": "",
    "build:prod": "lerna run build:prod --parallel",
    "********** Test": "",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --no-colors && lerna run test",
    "********** Version": "",
    "preversion": "lerna run build:prod --parallel",
    "version": "lerna version --no-private --conventional-commits --changelog-preset conventionalcommits --yes --ignore-changes '**/package-lock.json'",
    "********** Publish": "",
    "publish:ci": "lerna publish from-git --yes --no-verify-access",
    "publish:ci:beta": "lerna publish --dist-tag beta from-git --yes --no-verify-access"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tramvaijs/linters.git"
  },
  "devDependencies": {
    "@babel/core": "^7.21.4",
    "@babel/preset-env": "^7.21.4",
    "@babel/preset-typescript": "^7.21.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tinkoff/eslint-config": "file:./packages/eslint-config",
    "@tinkoff/eslint-plugin": "file:./packages/eslint-plugin",
    "@tinkoff/prettier-config": "file:./packages/prettier-config",
    "@types/eslint": "^9.6.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.17.11",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-jest": "^29.5.0",
    "concurrently": "5.0.1",
    "conventional-changelog-conventionalcommits": "^4.2.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-decorator-position": "^6.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^7.0.4",
    "jest": "^29.5.0",
    "lerna": "^4.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5",
    "react": "^16.13.0",
    "react-dom": "^16.13.0",
    "typescript": "5.1.6"
  }
}
